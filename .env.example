# =====================================================
# KIREIDOT Salonboard Worker
# =====================================================
# KIREIDOT Admin の URL
# ローカル開発: http://localhost:3000
# 本番: https://<your-vercel-domain>
KIREIDOT_API_URL=http://localhost:3000

# 実行モード
#   device      … 本番。Admin で発行された device_id / device_token を使う。
#   central-dev … 開発専用 (Admin が NODE_ENV!='production' のときだけ通る)。
WORKER_MODE=device

# --- device モード用 (WORKER_MODE=device) ---
# Admin の "/admin/salonboard/devices" 画面で発行された値を貼る。
# device_token は発行時に1度だけ表示される平文トークン。
SALONBOARD_DEVICE_ID=
SALONBOARD_DEVICE_TOKEN=

# --- central-dev モード用 (WORKER_MODE=central-dev) ---
# KIREIDOT_Admin/.env.local の SALONBOARD_WORKER_TOKEN と完全一致させること。
SALONBOARD_WORKER_TOKEN=

# 任意のワーカー識別子 (ログや job.locked_by に使われる)
WORKER_ID=local-dev-01

# Worker のアプリバージョン (省略時は package.json から自動取得)
# APP_VERSION=0.1.29

# ポーリング間隔 (ミリ秒)。デフォルト 30秒
POLL_INTERVAL_MS=30000

# ドライラン: true にすると Playwright は起動せず、ジョブを即 succeeded で callback する
DRY_RUN=false

# =====================================================
# KIREIDOT サロンデスク (Electron + Vite) 用
# Vite では VITE_* プレフィックスのみブラウザ側に露出する
# =====================================================
VITE_SUPABASE_URL=https://cxbqbjrxsuuabhxlrdpz.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_APP_NAME=KIREIDOT サロンデスク

# =====================================================
# macOS Notarization (Apple 公証)
# 推奨: Keychain profile 方式
#   ターミナルで一度だけ:
#     xcrun notarytool store-credentials "予約同期くん-notary" \
#       --apple-id <YOUR_APPLE_ID> \
#       --team-id 7FMVQPBJKA \
#       --password <APP-SPECIFIC-PASSWORD>
#   その後、ここに profile 名だけを書く (秘密情報は Keychain 内)
APPLE_NOTARY_KEYCHAIN_PROFILE=予約同期くん-notary

# 環境変数方式 (Keychain が使えない CI 等で使用)
# 上記の APPLE_NOTARY_KEYCHAIN_PROFILE が設定されていない場合のフォールバック。
# 実値は絶対に Git に含めない。
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_TEAM_ID=7FMVQPBJKA

# 公証をスキップしたい場合 (社内開発向けのテスト dmg 作成)
# SKIP_NOTARIZE=1
