{
  "name": "kireidot-salondesk",
  "version": "0.2.154",
  "private": true,
  "description": "KIREIDOT サロンデスク — サロン業務 (予約・スタッフ・シフト・ブログ) を一元管理する Electron デスクトップアプリ",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "worker:dev": "tsx worker.ts",
    "worker:once": "tsx worker.ts --once",
    "worker:dry-run": "DRY_RUN=1 tsx worker.ts",
    "worker:inspect": "tsx inspect.ts",
    "test:push": "tsx test-push-booking.ts",
    "test:push:write": "cross-env SALONBOARD_ENABLE_PUSH=true tsx test-push-booking.ts",
    "playwright:install": "npx playwright install chromium chromium-headless-shell",
    "playwright:copy": "node build-resources/copy-playwright-browsers.cjs",
    "prebuild:dist": "npm run playwright:install && npm run playwright:copy",
    "dist": "npm run prebuild:dist && npm run build && electron-builder",
    "dist:mac": "npm run prebuild:dist && npm run build && electron-builder --mac --publish never",
    "dist:mac:arm64": "npm run prebuild:dist && npm run build && electron-builder --mac --arm64 --publish never",
    "dist:mac:nosign": "SKIP_NOTARIZE=1 npm run dist:mac:arm64",
    "publish:mac:arm64": "npm run prebuild:dist && npm run build && electron-builder --mac --arm64 --publish always",
    "verify:mac": "bash build-resources/verify-mac.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.451.0",
    "playwright": "^1.49.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "jp.kireidot.salondesk",
    "productName": "予約同期くん",
    "artifactName": "salonboard-sync-${os}-${arch}.${ext}",
    "afterSign": "build-resources/notarize.cjs",
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build-resources/playwright-browsers",
        "to": "playwright-browsers",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": "HIKARU UEDA (7FMVQPBJKA)",
      "gatekeeperAssess": false,
      "hardenedRuntime": true,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist",
      "type": "distribution"
    },
    "protocols": [
      {
        "name": "KIREIDOT サロンデスク",
        "schemes": [
          "kireidot-salondesk"
        ]
      }
    ],
    "dmg": {
      "writeUpdateInfo": true,
      "sign": false
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Nolan-inc",
        "repo": "KIREIDOT_Salonboard_Worker",
        "releaseType": "release",
        "publishAutoUpdate": true
      }
    ]
  }
}
